# ── Groq API ─────────────────────────────────────────────
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

LLM_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# ── Tavily API ───────────────────────────────────────────
# Get your key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith Tracing (optional) ─────────────────────────
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=whatsapp-myth-buster

# ── Qdrant ────────────────────────────────────────────────
QDRANT_PATH=./qdrant_storage
QDRANT_FACT_COLLECTION=fact_check_db
QDRANT_MEMORY_COLLECTION=verdict_memory

# ── Models ────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# ── Retrieval / Reranking ─────────────────────────────────
TOP_K_RETRIEVAL=10
TOP_K_RERANKED=3
MAX_RETRY_COUNT=2
REFLECTION_THRESHOLD=0.4

# ── Data ──────────────────────────────────────────────────
IFND_CSV_PATH=./data/raw/IFND.csv